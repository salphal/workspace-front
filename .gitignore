# 🚫 Git 忽略文件配置
# ============================================
# 忽略以下文件和目录，不提交到版本控制
# ============================================

# 📦 依赖包目录
node_modules/

# 🔨 构建输出目录
dist/
dist-ssr/
build/
out/

# 📁 缓存目录
.cache/
.vscode/
.idea/
.history/

# 📊 覆盖率报告
coverage/

# 📝 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 🔧 配置文件（通常包含敏感信息）
.env.*

# 📊 其他构建产物
*.min.css
*.min.js

# 📋 特定文件
.DS_Store
.stylelintcache
qodana.yaml

# 🧪 测试相关快照文件
*.snap

# 📊 其他忽略项
LICENSE
AUTHORS.txt
CNAME
netlify.toml
yarn-error.log

# 🔒 系统文件
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 🛠️ 开发工具相关
/.husky/
stats.html
vite.config.ts.timestamp-*

# 🗂️ 临时文件
*.local
__output__
auto-imports.d.ts
.dev-cli/__template__

# 💾 数据库文件
*.db
*.sqlite
*.sqlite3

# 📦 包管理器缓存
.pnpm-store/
.yarn/
.npm/
