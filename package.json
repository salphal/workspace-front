  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "cf:login": "wrangler login",
    "cf:deploy": "pnpm run build && wrangler deploy",
    "husky": "echo 'npx lint-staged' > .husky/pre-commit && echo 'npx --no-install commitlint --edit $1' > .husky/commit-msg",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 100 --fix",
    "prettier:lint": "prettier . --write",
    "prettier:fix": "prettier . --write",
    "style:lint": "stylelint \"src/**/*.(scss)\"",
    "style:fix": "stylelint \"src/**/*.(scss)\" --fix",
    "tailwindcss": "npx tailwindcss -i ./src/main.scss -o ./public/tailwind.css --watch && npx tailwindcss -o ./public/tailwind.css --minify",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
